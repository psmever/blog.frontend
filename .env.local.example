# Copy to .env.local for local development
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_CLIENT_HEADER_CODE=CT04P
NEXT_PUBLIC_APP_NAME=My Blog
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_DEBUG_MODE=true
LOCAL_LOGIN_EMAIL=admin@example.com
LOCAL_LOGIN_PASSWORD=password

# Server-only secrets stay on the server (not prefixed with NEXT_PUBLIC_)
SECRET_API_KEY=YOUR_INTERNAL_SECRET_KEY
